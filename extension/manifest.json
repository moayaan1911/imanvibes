{
  "manifest_version": 3,
  "name": "ImanVibes Salah Companion",
  "description": "Track daily prayers, view accurate timings, and get Salah reminders while you browse.",
  "version": "0.0.1",
  "action": {
    "default_title": "ImanVibes Salah Companion",
    "default_popup": "popup.html",
    "default_icon": {
      "128": "assets/icon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "assets/icon.png"
  },
  "permissions": ["geolocation", "storage", "notifications", "alarms"],
  "host_permissions": [
    "https://api.aladhan.com/*",
    "https://geocoding-api.open-meteo.com/*"
  ]
}

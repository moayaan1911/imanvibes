{
  "manifest_version": 3,
  "name": "ImanVibes Prayer Companion",
  "description": "Location-based Salah timings, countdown, tracker, and schedule for ImanVibes.",
  "version": "0.0.1",
  "action": {
    "default_title": "ImanVibes",
    "default_popup": "popup.html",
    "default_icon": {
      "128": "assets/icon.png"
    }
  },
  "icons": {
    "128": "assets/icon.png"
  },
  "permissions": ["geolocation", "storage"],
  "host_permissions": [
    "https://api.aladhan.com/*",
    "https://geocoding-api.open-meteo.com/*"
  ]
}
